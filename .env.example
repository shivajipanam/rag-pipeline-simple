# Required: Get free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Required: Get free key at https://www.pinecone.io/
# Create an index named "rag-workshop" with 384 dimensions (cosine metric)
PINECONE_API_KEY=your_pinecone_api_key_here

# Optional: override the default Pinecone index name
# PINECONE_INDEX_NAME=rag-workshop

# Optional: HuggingFace Inference API key (free tier at huggingface.co/settings/tokens)
# When set, embeddings are computed via API call instead of loading the
# sentence-transformers/all-MiniLM-L6-v2 model locally — saves ~25 MB RAM.
# HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: maximum upload file size in MB (default: 5 for free tier)
# Set higher (e.g. 500) for Pro users once authentication is in place.
# MAX_UPLOAD_MB=5

# Optional: session TTL in hours — sessions inactive longer than this are
# evicted by the background cleanup task and their Pinecone data is deleted.
# SESSION_TTL_HOURS=2

# Optional: how often (seconds) the cleanup task runs (default: 300 = 5 min)
# SESSION_CLEANUP_INTERVAL_SECONDS=300

# Contact Sales email credentials (Gmail App Password required)
# CONTACT_EMAIL_USER=your-gmail@gmail.com
# CONTACT_EMAIL_PASS=xxxx xxxx xxxx xxxx
